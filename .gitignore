# Both forms: a trailing slash matches a directory only, and a `node_modules`
# that is a *symlink* (a worktree pointed at the main checkout's copy, say) is a
# file — so `node_modules/` alone let one be committed.
node_modules
node_modules/
dist/
*.db
*.db-wal
*.db-shm
*.log
.DS_Store
.env
.env.local
web/dist/

# python
__pycache__/
*.pyc

# desktop app build output (electron-builder) lives in electron/ and is
# ignored there — the sidecar is a ~100MB compiled server binary.
.claude/
*.bun-build
